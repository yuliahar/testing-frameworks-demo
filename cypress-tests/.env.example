# Qase.io Configuration for Cypress Reporter v2.x+
# Copy this file to .env and fill in your values

# Qase API Token (get from https://app.qase.io/user/api/token)
QASE_TESTOPS_API_TOKEN=your_api_token_here

# Qase Project Code (found in your project URL: https://app.qase.io/project/YOUR_CODE)
QASE_TESTOPS_PROJECT=YOUR_PROJECT_CODE

# Qase Mode: off, testops (default: off)
# off - Qase reporting disabled
# testops - Report results to Qase TestOps
QASE_MODE=testops

# Run Configuration
QASE_TESTOPS_RUN_TITLE=Cypress UI Tests - Automated Run
QASE_TESTOPS_RUN_DESCRIPTION=Automated UI/E2E tests from CI/CD
QASE_TESTOPS_RUN_COMPLETE=true

# Debug mode (set to true for verbose logging)
QASE_DEBUG=false

# Cypress Base URL
CYPRESS_BASE_URL=http://localhost:3000
